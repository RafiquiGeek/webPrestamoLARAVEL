APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
LOG_LEVEL_DB_SYNC=info

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=santiago_system
DB_USERNAME=root
DB_PASSWORD=

# Configuración de base de datos secundaria para backup
DB_BACKUP_HOST=127.0.0.1
DB_BACKUP_PORT=3306
DB_BACKUP_DATABASE=grupo_backup
DB_BACKUP_USERNAME=root
DB_BACKUP_PASSWORD=

# Configuración de base de datos para analytics
DB_ANALYTICS_HOST=127.0.0.1
DB_ANALYTICS_PORT=3306
DB_ANALYTICS_DATABASE=grupo_analytics
DB_ANALYTICS_USERNAME=root
DB_ANALYTICS_PASSWORD=

# Configuración de sincronización de datos
DB_SYNC_ENABLED=true

# Configuración SSL para bases de datos secundarias
# Certificados SSL para conexión backup
MYSQL_BACKUP_ATTR_SSL_CA=/path/to/ca-cert.pem
MYSQL_BACKUP_ATTR_SSL_CERT=/path/to/client-cert.pem
MYSQL_BACKUP_ATTR_SSL_KEY=/path/to/client-key.pem
MYSQL_BACKUP_SSL_VERIFY=true
MYSQL_BACKUP_SSL_CIPHER=

# Certificados SSL para conexión analytics
MYSQL_ANALYTICS_ATTR_SSL_CA=/path/to/ca-cert.pem
MYSQL_ANALYTICS_ATTR_SSL_CERT=/path/to/client-cert.pem
MYSQL_ANALYTICS_ATTR_SSL_KEY=/path/to/client-key.pem
MYSQL_ANALYTICS_SSL_VERIFY=true
MYSQL_ANALYTICS_SSL_CIPHER=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
# Para producción usar redis o sqs para mejor rendimiento
# QUEUE_CONNECTION=redis
SESSION_DRIVER=database
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
